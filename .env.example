# Unified MiniMax MCP（统一 MiniMax MCP）environment example

# Token Plan key（Token Plan 专用 Key）.
MINIMAX_TOKEN_PLAN_API_KEY=PUT_YOUR_TOKEN_PLAN_KEY_HERE

# API host（接口地址）.
# Global: https://api.minimax.io
# Mainland: https://api.minimaxi.com
MINIMAX_API_HOST=https://api.minimax.io

# Local output base path（本地输出根目录）.
MINIMAX_MCP_BASE_PATH=~/Desktop

# Resource mode（资源输出模式）: url | local
MINIMAX_API_RESOURCE_MODE=local

# FastMCP log level（日志级别）.
FASTMCP_LOG_LEVEL=WARNING
